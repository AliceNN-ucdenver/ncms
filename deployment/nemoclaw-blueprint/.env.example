# NCMS NemoClaw Blueprint — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Then run:
#   ./build_and_run.sh --env-file .env

# ── Build-time (model downloads) ──────────────────────────────────────────
# HuggingFace token for SPLADE v3 (gated model, ~500 MB)
# Get yours at: https://huggingface.co/settings/tokens
# Then accept the license at: https://huggingface.co/naver/splade-v3
HF_TOKEN=

# ── Runtime (API keys) ───────────────────────────────────────────────────
# Only needed for NIM profile or OpenAI-compatible endpoints
NVIDIA_API_KEY=
OPENAI_API_KEY=
